generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Authenticator {
  credentialID         String  @unique
  user_id              String  @db.Char(36)
  provider_account_id  String  @db.VarChar(255)
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  users                users   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([user_id, credentialID])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model account_deletion_requests {
  request_id                                                String                           @id @db.Char(36)
  user_id                                                   String                           @db.Char(36)
  profile_id                                                String                           @db.Char(36)
  status                                                    account_deletion_requests_status @default(PENDING)
  reason                                                    String?                          @db.Text
  email                                                     String                           @db.VarChar(255)
  processed_by                                              String?                          @db.Char(36)
  processed_at                                              DateTime?
  rejection_reason                                          String?                          @db.Text
  created_at                                                DateTime                         @default(now())
  updated_at                                                DateTime                         @default(now())
  profiles_account_deletion_requests_processed_byToprofiles profiles?                        @relation("account_deletion_requests_processed_byToprofiles", fields: [processed_by], references: [profile_id])
  profiles_account_deletion_requests_profile_idToprofiles   profiles                         @relation("account_deletion_requests_profile_idToprofiles", fields: [profile_id], references: [profile_id], onDelete: Cascade)
  users                                                     users                            @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([processed_by], map: "account_deletion_requests_processed_by_fkey")
  @@index([profile_id], map: "idx_profile_id")
  @@index([status], map: "idx_status")
  @@index([user_id], map: "idx_user_id")
}

model accounts {
  account_id          String   @id @db.Char(36)
  user_id             String   @db.Char(36)
  type                String   @db.VarChar(50)
  provider            String   @db.VarChar(50)
  provider_account_id String   @db.VarChar(255)
  refresh_token       String?  @db.Text
  access_token        String?  @db.Text
  expires_at          Int?
  token_type          String?  @db.VarChar(50)
  scope               String?  @db.VarChar(255)
  id_token            String?  @db.Text
  session_state       String?  @db.VarChar(255)
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now())
  users               users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([provider, provider_account_id])
  @@index([user_id])
}

model audio_contents {
  audio_content_id String   @id @db.Char(36)
  lesson_id        String   @unique @db.Char(36)
  audio_url        String   @db.Text
  duration         Int
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())
  lessons          lessons  @relation(fields: [lesson_id], references: [lesson_id], onDelete: Cascade)
}

model author_applications {
  application_id                                     String                     @id @db.Char(36)
  profile_id                                         String                     @db.Char(36)
  status                                             author_applications_status @default(PENDING)
  motivation                                         String                     @db.Text
  experience                                         String?                    @db.Text
  portfolio_url                                      String?                    @db.VarChar(500)
  reviewed_by                                        String?                    @db.Char(36)
  reviewed_at                                        DateTime?
  rejection_reason                                   String?                    @db.Text
  created_at                                         DateTime                   @default(now())
  updated_at                                         DateTime                   @default(now())
  profiles_author_applications_profile_idToprofiles  profiles                   @relation("author_applications_profile_idToprofiles", fields: [profile_id], references: [profile_id], onDelete: Cascade)
  profiles_author_applications_reviewed_byToprofiles profiles?                  @relation("author_applications_reviewed_byToprofiles", fields: [reviewed_by], references: [profile_id])

  @@index([profile_id])
  @@index([reviewed_by], map: "author_applications_reviewed_by_fkey")
  @@index([status])
}

model business_events {
  event_id       String                       @id @db.Char(36)
  profile_id     String?                      @db.Char(36)
  event_type     String                       @db.VarChar(100)
  event_category String                       @db.VarChar(50)
  object_type    business_events_object_type?
  object_id      String?                      @db.Char(36)
  metadata       Json?
  ip_address     String?                      @db.VarChar(45)
  user_agent     String?                      @db.Text
  session_id     String?                      @db.VarChar(255)
  created_at     DateTime                     @default(now())
  profiles       profiles?                    @relation(fields: [profile_id], references: [profile_id])

  @@index([created_at])
  @@index([event_type])
  @@index([profile_id])
}

model certificates {
  certificate_id     String   @id @db.Char(36)
  profile_id         String   @db.Char(36)
  course_id          String   @db.Char(36)
  issued_at          DateTime @default(now())
  completed_at       DateTime
  image_url          String?  @db.Text
  pdf_url            String?  @db.Text
  certificate_number String   @unique @db.VarChar(50)
  metadata           Json?
  courses            courses  @relation(fields: [course_id], references: [course_id], onDelete: Cascade)
  profiles           profiles @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)

  @@unique([profile_id, course_id])
  @@index([course_id], map: "certificates_course_id_fkey")
}

model comments {
  comment_id                                    String                    @id @db.Char(36)
  commentable_type                              comments_commentable_type
  commentable_id                                String                    @db.Char(36)
  author_profile_id                             String                    @db.Char(36)
  text                                          String                    @db.Text
  status                                        comments_status           @default(PENDING)
  moderated_by                                  String?                   @db.Char(36)
  moderated_at                                  DateTime?
  likes_count                                   Int                       @default(0)
  created_at                                    DateTime                  @default(now())
  updated_at                                    DateTime                  @default(now())
  deleted_at                                    DateTime?
  profiles_comments_author_profile_idToprofiles profiles                  @relation("comments_author_profile_idToprofiles", fields: [author_profile_id], references: [profile_id])
  profiles_comments_moderated_byToprofiles      profiles?                 @relation("comments_moderated_byToprofiles", fields: [moderated_by], references: [profile_id])

  @@index([author_profile_id])
  @@index([commentable_type, commentable_id])
  @@index([created_at])
  @@index([moderated_by], map: "comments_moderated_by_fkey")
  @@index([status])
}

model course_progress {
  course_progress_id String    @id @db.Char(36)
  profile_id         String    @db.Char(36)
  course_id          String    @db.Char(36)
  status             String    @default("not_started")
  progress_percent   Int       @default(0)
  completed_lessons  Int       @default(0)
  total_lessons      Int       @default(0)
  started_at         DateTime?
  completed_at       DateTime?
  last_viewed_at     DateTime  @default(now())
  courses            courses   @relation(fields: [course_id], references: [course_id], onDelete: Cascade)
  profiles           profiles  @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)

  @@unique([profile_id, course_id])
  @@index([course_id], map: "course_progress_course_id_fkey")
}

model course_tags {
  course_tag_id String  @id @db.Char(36)
  course_id     String  @db.Char(36)
  tag_id        String  @db.Char(36)
  courses       courses @relation(fields: [course_id], references: [course_id], onDelete: Cascade)
  tags          tags    @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade)

  @@unique([course_id, tag_id])
  @@index([tag_id], map: "course_tags_tag_id_fkey")
}

model courses {
  course_id         String                    @id @db.Char(36)
  title             String                    @db.VarChar(255)
  slug              String                    @unique @db.VarChar(255)
  description       String?                   @db.Text
  cover_image       String?                   @db.Text
  difficulty_level  courses_difficulty_level?
  duration          Int?
  lessons_count     Int                       @default(0)
  modules_count     Int                       @default(0)
  status            courses_status            @default(DRAFT)
  is_premium        Boolean                   @default(false)
  published_at      DateTime?
  author_profile_id String                    @db.Char(36)
  views_count       Int                       @default(0)
  likes_count       Int                       @default(0)
  created_at        DateTime                  @default(now())
  updated_at        DateTime                  @default(now())
  deleted_at        DateTime?
  certificates      certificates[]
  course_progress   course_progress[]
  course_tags       course_tags[]
  profiles          profiles                  @relation(fields: [author_profile_id], references: [profile_id])
  modules           modules[]

  @@index([author_profile_id])
  @@index([slug])
  @@index([status])
}

model favorites {
  favorite_id String   @id @db.Char(36)
  profile_id  String   @db.Char(36)
  lesson_id   String   @db.Char(36)
  note        String?  @db.Text
  collection  String?  @db.VarChar(100)
  created_at  DateTime @default(now())
  lessons     lessons  @relation(fields: [lesson_id], references: [lesson_id], onDelete: Cascade)
  profiles    profiles @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)

  @@unique([profile_id, lesson_id])
  @@index([collection])
  @@index([lesson_id])
  @@index([profile_id])
}

model history {
  history_id      String                  @id @db.Char(36)
  profile_id      String                  @db.Char(36)
  historable_type history_historable_type
  historable_id   String                  @db.Char(36)
  watched_seconds Int?
  completed       Boolean                 @default(false)
  viewed_at       DateTime                @default(now())
  profiles        profiles                @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)

  @@unique([profile_id, historable_type, historable_id])
  @@index([profile_id])
  @@index([viewed_at])
}

model lesson_progress {
  lesson_progress_id String    @id @db.Char(36)
  profile_id         String    @db.Char(36)
  lesson_id          String    @db.Char(36)
  status             String    @default("not_started")
  progress_percent   Int       @default(0)
  last_position      Int?
  quiz_score         Int?
  quiz_completed     Boolean   @default(false)
  started_at         DateTime?
  completed_at       DateTime?
  last_viewed_at     DateTime  @default(now())
  lessons            lessons   @relation(fields: [lesson_id], references: [lesson_id], onDelete: Cascade)
  profiles           profiles  @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)

  @@unique([profile_id, lesson_id])
  @@index([lesson_id], map: "lesson_progress_lesson_id_fkey")
}

model lesson_tags {
  lesson_tag_id String  @id @db.Char(36)
  lesson_id     String  @db.Char(36)
  tag_id        String  @db.Char(36)
  lessons       lessons @relation(fields: [lesson_id], references: [lesson_id], onDelete: Cascade)
  tags          tags    @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade)

  @@unique([lesson_id, tag_id])
  @@index([tag_id], map: "lesson_tags_tag_id_fkey")
}

model lessons {
  lesson_id         String              @id @db.Char(36)
  module_id         String?             @db.Char(36)
  title             String              @db.VarChar(255)
  slug              String              @unique @db.VarChar(255)
  description       String?             @db.Text
  lesson_type       lessons_lesson_type @default(ARTICLE)
  sort_order        Int                 @default(0)
  duration          Int?
  cover_image       String?             @db.Text
  author_profile_id String              @db.Char(36)
  is_premium        Boolean             @default(false)
  status            lessons_status      @default(DRAFT)
  published_at      DateTime?
  views_count       Int                 @default(0)
  likes_count       Int                 @default(0)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @default(now())
  deleted_at        DateTime?
  audio_contents    audio_contents?
  favorites         favorites[]
  lesson_progress   lesson_progress[]
  lesson_tags       lesson_tags[]
  profiles          profiles            @relation(fields: [author_profile_id], references: [profile_id])
  modules           modules?            @relation(fields: [module_id], references: [module_id])
  quiz_contents     quiz_contents?
  text_contents     text_contents?
  video_contents    video_contents?

  @@index([author_profile_id])
  @@index([lesson_type])
  @@index([module_id])
  @@index([slug])
  @@index([status])
}

model modules {
  module_id     String    @id @db.Char(36)
  course_id     String    @db.Char(36)
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  sort_order    Int       @default(0)
  lessons_count Int       @default(0)
  duration      Int?
  is_published  Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now())
  lessons       lessons[]
  courses       courses   @relation(fields: [course_id], references: [course_id], onDelete: Cascade)

  @@index([course_id])
  @@index([sort_order])
}

model notifications {
  notification_id String             @id @db.Char(36)
  profile_id      String             @db.Char(36)
  type            notifications_type
  channel         String             @db.VarChar(50)
  title           String             @db.VarChar(255)
  body            String             @db.Text
  data            Json?
  link_url        String?            @db.Text
  is_read         Boolean            @default(false)
  is_sent         Boolean            @default(false)
  external_id     String?            @db.VarChar(255)
  error_message   String?            @db.Text
  scheduled_for   DateTime?
  sent_at         DateTime?
  read_at         DateTime?
  created_at      DateTime           @default(now())
  profiles        profiles           @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)

  @@index([created_at])
  @@index([is_read])
  @@index([profile_id])
}

model payment_methods {
  payment_method_id String          @id @db.Char(36)
  profile_id        String          @db.Char(36)
  type              String          @db.VarChar(50)
  provider          String          @db.VarChar(50)
  provider_token    String          @db.Text
  last4             String?         @db.VarChar(4)
  card_type         String?         @db.VarChar(50)
  expiry_month      Int?
  expiry_year       Int?
  phone_number      String?         @db.VarChar(20)
  is_default        Boolean         @default(false)
  is_verified       Boolean         @default(false)
  is_expired        Boolean         @default(false)
  metadata          Json?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @default(now())
  deleted_at        DateTime?
  profiles          profiles        @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)
  subscriptions     subscriptions[]
  transactions      transactions[]

  @@index([profile_id])
}

model profiles {
  profile_id                                                                 String                      @id @db.Char(36)
  user_id                                                                    String                      @unique @db.Char(36)
  nickname                                                                   String                      @unique @db.VarChar(50)
  display_name                                                               String                      @db.VarChar(255)
  avatar_url                                                                 String?                     @db.Text
  cover_image                                                                String?                     @db.Text
  bio                                                                        String?                     @db.Text
  website                                                                    String?                     @db.VarChar(255)
  telegram                                                                   String?                     @db.VarChar(100)
  youtube                                                                    String?                     @db.VarChar(100)
  total_views                                                                Int                         @default(0)
  subscribers                                                                Int                         @default(0)
  created_at                                                                 DateTime                    @default(now())
  updated_at                                                                 DateTime                    @default(now())
  account_deletion_requests_account_deletion_requests_processed_byToprofiles account_deletion_requests[] @relation("account_deletion_requests_processed_byToprofiles")
  account_deletion_requests_account_deletion_requests_profile_idToprofiles   account_deletion_requests[] @relation("account_deletion_requests_profile_idToprofiles")
  author_applications_author_applications_profile_idToprofiles               author_applications[]       @relation("author_applications_profile_idToprofiles")
  author_applications_author_applications_reviewed_byToprofiles              author_applications[]       @relation("author_applications_reviewed_byToprofiles")
  business_events                                                            business_events[]
  certificates                                                               certificates[]
  comments_comments_author_profile_idToprofiles                              comments[]                  @relation("comments_author_profile_idToprofiles")
  comments_comments_moderated_byToprofiles                                   comments[]                  @relation("comments_moderated_byToprofiles")
  course_progress                                                            course_progress[]
  courses                                                                    courses[]
  favorites                                                                  favorites[]
  history                                                                    history[]
  lesson_progress                                                            lesson_progress[]
  lessons                                                                    lessons[]
  notifications                                                              notifications[]
  payment_methods                                                            payment_methods[]
  users                                                                      users                       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  reactions                                                                  reactions[]
  subscriptions                                                              subscriptions[]
  transactions                                                               transactions[]

  @@index([nickname])
  @@index([user_id])
}

model quiz_contents {
  quiz_content_id  String   @id @db.Char(36)
  lesson_id        String   @unique @db.Char(36)
  questions        Json
  passing_score    Int      @default(70)
  attempts_allowed Int?
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())
  lessons          lessons  @relation(fields: [lesson_id], references: [lesson_id], onDelete: Cascade)
}

model reactions {
  reaction_id       String                      @id @db.Char(36)
  type              reactions_type
  profile_id        String                      @db.Char(36)
  reactionable_type reactions_reactionable_type
  reactionable_id   String                      @db.Char(36)
  created_at        DateTime                    @default(now())
  profiles          profiles                    @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)

  @@unique([profile_id, reactionable_type, reactionable_id])
  @@index([profile_id])
  @@index([reactionable_type, reactionable_id])
}

model sessions {
  session_id    String   @id @db.Char(36)
  session_token String   @unique @db.VarChar(255)
  user_id       String   @db.Char(36)
  expires       DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())
  users         users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([session_token])
  @@index([user_id])
}

model subscriptions {
  subscription_id          String               @id @db.Char(36)
  profile_id               String               @db.Char(36)
  plan_type                String               @db.VarChar(50)
  status                   subscriptions_status @default(ACTIVE)
  start_date               DateTime             @default(now())
  end_date                 DateTime?
  trial_ends_at            DateTime?
  auto_renew               Boolean              @default(true)
  cancel_at_period_end     Boolean              @default(false)
  price                    Float
  currency                 String               @default("RUB") @db.VarChar(3)
  payment_method_id        String?              @db.Char(36)
  provider_subscription_id String?              @db.VarChar(255)
  provider                 String?              @db.VarChar(50)
  created_at               DateTime             @default(now())
  updated_at               DateTime             @default(now())
  canceled_at              DateTime?
  deleted_at               DateTime?
  payment_methods          payment_methods?     @relation(fields: [payment_method_id], references: [payment_method_id])
  profiles                 profiles             @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)
  transactions             transactions[]

  @@index([payment_method_id], map: "subscriptions_payment_method_id_fkey")
  @@index([profile_id])
  @@index([status])
}

model tags {
  tag_id      String        @id @db.Char(36)
  name        String        @unique @db.VarChar(50)
  slug        String        @unique @db.VarChar(50)
  color       String?       @db.VarChar(7)
  course_tags course_tags[]
  lesson_tags lesson_tags[]
}

model text_contents {
  text_content_id String   @id @db.Char(36)
  lesson_id       String   @unique @db.Char(36)
  body            String   @db.Text
  word_count      Int?
  reading_time    Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  lessons         lessons  @relation(fields: [lesson_id], references: [lesson_id], onDelete: Cascade)
}

model transactions {
  transaction_id      String              @id @db.Char(36)
  profile_id          String              @db.Char(36)
  subscription_id     String?             @db.Char(36)
  type                String              @db.VarChar(50)
  amount              Float
  currency            String              @default("RUB") @db.VarChar(3)
  status              transactions_status @default(PENDING)
  course_id           String?             @db.Char(36)
  payment_method_id   String?             @db.Char(36)
  provider            String              @db.VarChar(50)
  provider_payment_id String?             @db.VarChar(255)
  provider_response   Json?
  refunded_at         DateTime?
  refund_amount       Float?
  refund_reason       String?             @db.Text
  created_at          DateTime            @default(now())
  updated_at          DateTime            @default(now())
  completed_at        DateTime?
  failed_at           DateTime?
  payment_methods     payment_methods?    @relation(fields: [payment_method_id], references: [payment_method_id])
  profiles            profiles            @relation(fields: [profile_id], references: [profile_id], onDelete: Cascade)
  subscriptions       subscriptions?      @relation(fields: [subscription_id], references: [subscription_id])

  @@index([course_id])
  @@index([payment_method_id], map: "transactions_payment_method_id_fkey")
  @@index([profile_id])
  @@index([status])
  @@index([subscription_id])
}

model users {
  user_id                   String                      @id @db.Char(36)
  email                     String                      @unique @db.VarChar(255)
  first_name                String                      @db.VarChar(100)
  last_name                 String                      @db.VarChar(100)
  password_hash             String?                     @db.VarChar(255)
  role                      users_role                  @default(USER)
  email_verified            DateTime?
  is_blocked                Boolean                     @default(false)
  blocked_reason            String?                     @db.Text
  last_login_at             DateTime?
  created_at                DateTime                    @default(now())
  updated_at                DateTime                    @default(now())
  deleted_at                DateTime?
  Authenticator             Authenticator[]
  account_deletion_requests account_deletion_requests[]
  accounts                  accounts[]
  profiles                  profiles?
  sessions                  sessions[]

  @@index([created_at])
  @@index([email])
  @@index([role])
}

model video_contents {
  video_content_id String                  @id @db.Char(36)
  lesson_id        String                  @unique @db.Char(36)
  video_url        String                  @db.Text
  provider         video_contents_provider @default(YOUTUBE)
  duration         Int
  qualities        Json?
  subtitles        Json?
  created_at       DateTime                @default(now())
  updated_at       DateTime                @default(now())
  lessons          lessons                 @relation(fields: [lesson_id], references: [lesson_id], onDelete: Cascade)
}

enum comments_commentable_type {
  COURSE
  LESSON
}

enum reactions_type {
  LIKE
  DISLIKE
}

enum author_applications_status {
  PENDING
  APPROVED
  REJECTED
}

enum history_historable_type {
  LESSON
  STANDALONE_ARTICLE
}

enum notifications_type {
  EMAIL
  IN_APP
  TELEGRAM
}

enum account_deletion_requests_status {
  PENDING
  COMPLETED
  REJECTED
  CANCELLED
}

enum reactions_reactionable_type {
  COURSE
  LESSON
  COMMENT
}

enum subscriptions_status {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum video_contents_provider {
  YOUTUBE
  RUTUBE
  VIMEO
  LOCAL
}

enum business_events_object_type {
  COURSE
  LESSON
  COMMENT
  SUBSCRIPTION
}

enum comments_status {
  PENDING
  APPROVED
  REJECTED
}

enum courses_difficulty_level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum lessons_lesson_type {
  ARTICLE
  VIDEO
  AUDIO
  QUIZ
  CALCULATOR
}

enum users_role {
  USER
  AUTHOR
  MODERATOR
  ADMIN
}

enum transactions_status {
