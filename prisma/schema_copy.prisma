// Optimized Prisma Schema v2 - MySQL Version
// Конвертировано с PostgreSQL на MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// Enums (без изменений)
enum Role {
  USER
  AUTHOR
  MODERATOR
  ADMIN
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
  DELETED
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum VideoProvider {
  YOUTUBE
  RUTUBE
  VIMEO
  LOCAL
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationType {
  EMAIL
  IN_APP
  TELEGRAM
}

enum AuthProvider {
  EMAIL
  GOOGLE
  VK
  YANDEX
  GITHUB
}

enum StorageProvider {
  VERCEL_BLOB
  AWS_S3
  CLOUDINARY
  LOCAL
}

enum BusinessObjectType {
  COURSE
  LESSON
  COMMENT
  SUBSCRIPTION
}

enum HistorableType {
  LESSON
  STANDALONE_ARTICLE
}

enum LessonType {
  ARTICLE
  VIDEO
  AUDIO
  QUIZ
  CALCULATOR
}

enum CommentableType {
  COURSE
  LESSON
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum ReactionableType {
  COURSE
  LESSON
  COMMENT
}

// 1. КУРС
model Course {
  id             String    @id @default(uuid()) @map("course_id") @db.Char(36)
  title          String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(255)
  description    String?   @db.Text
  coverImage     String?   @map("cover_image") @db.Text
  
  difficultyLevel DifficultyLevel? @map("difficulty_level")
  duration       Int?      
  lessonsCount   Int       @default(0) @map("lessons_count")
  modulesCount   Int       @default(0) @map("modules_count")
  
  status         ContentStatus @default(DRAFT)
  isPremium      Boolean   @default(false) @map("is_premium")
  publishedAt    DateTime? @map("published_at") @db.DateTime(3)
  
  authorProfileId String   @map("author_profile_id") @db.Char(36)
  author         Profile   @relation(fields: [authorProfileId], references: [id])
  
  viewsCount     Int       @default(0) @map("views_count")
  likesCount     Int       @default(0) @map("likes_count")
  
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt      DateTime? @map("deleted_at") @db.DateTime(3)

  modules        Module[]
  tags           CourseTag[]
  progress       CourseProgress[]
  certificates   Certificate[]

  @@map("courses")
  @@index([slug])
  @@index([authorProfileId])
  @@index([status])
}

// 2. МОДУЛЬ
model Module {
  id             String    @id @default(uuid()) @map("module_id") @db.Char(36)
  courseId       String    @map("course_id") @db.Char(36)
  course         Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  title          String    @db.VarChar(255)
  description    String?   @db.Text
  sortOrder      Int       @default(0) @map("sort_order")
  
  lessonsCount   Int       @default(0) @map("lessons_count")
  duration       Int?      
  
  isPublished    Boolean   @default(false) @map("is_published")
  
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  lessons        Lesson[]

  @@map("modules")
  @@index([courseId])
  @@index([sortOrder])
}

// 3. УРОК
model Lesson {
  id             String    @id @default(uuid()) @map("lesson_id") @db.Char(36)
  moduleId       String?   @map("module_id") @db.Char(36)
  module         Module?   @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  
  title          String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(255)
  description    String?   @db.Text
  
  lessonType     LessonType @default(ARTICLE) @map("lesson_type")
  sortOrder      Int       @default(0) @map("sort_order")
  
  duration       Int?      
  coverImage     String?   @map("cover_image") @db.Text
  
  authorProfileId String   @map("author_profile_id") @db.Char(36)
  author         Profile   @relation(fields: [authorProfileId], references: [id])
  
  isPremium      Boolean   @default(false) @map("is_premium")
  status         ContentStatus @default(DRAFT)
  publishedAt    DateTime? @map("published_at") @db.DateTime(3)
  
  viewsCount     Int       @default(0) @map("views_count")
  likesCount     Int       @default(0) @map("likes_count")
  
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt      DateTime? @map("deleted_at") @db.DateTime(3)

  textContent    TextContent?
  videoContent   VideoContent?
  audioContent   AudioContent?
  quizContent    QuizContent?
  
  favorites      Favorite[]
  progress       LessonProgress[]
  tags           LessonTag[]

  @@map("lessons")
  @@index([slug])
  @@index([moduleId])
  @@index([authorProfileId])
  @@index([lessonType])
  @@index([status])
}

// 4. КОНТЕНТ-БЛОКИ

// Текстовый контент
model TextContent {
  id             String   @id @default(uuid()) @map("text_content_id") @db.Char(36)
  lessonId       String   @unique @map("lesson_id") @db.Char(36)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  body           String   @db.Text  // HTML или Markdown
  wordCount      Int?     @map("word_count")
  readingTime    Int?     @map("reading_time")
  
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("text_contents")
}

// Видео контент
model VideoContent {
  id             String        @id @default(uuid()) @map("video_content_id") @db.Char(36)
  lessonId       String        @unique @map("lesson_id") @db.Char(36)
  lesson         Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  videoUrl       String        @map("video_url") @db.Text
  provider       VideoProvider @default(YOUTUBE)
  duration       Int           
  
  qualities      Json?         @map("qualities") @db.Json
  subtitles      Json?         @map("subtitles") @db.Json
  
  createdAt      DateTime      @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("video_contents")
}

// Аудио контент
model AudioContent {
  id             String   @id @default(uuid()) @map("audio_content_id") @db.Char(36)
  lessonId       String   @unique @map("lesson_id") @db.Char(36)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  audioUrl       String   @map("audio_url") @db.Text
  duration       Int      
  
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("audio_contents")
}

// Тест/квиз
model QuizContent {
  id             String   @id @default(uuid()) @map("quiz_content_id") @db.Char(36)
  lessonId       String   @unique @map("lesson_id") @db.Char(36)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  questions      Json     @map("questions") @db.Json
  passingScore   Int      @default(70) @map("passing_score")
  attemptsAllowed Int?    @map("attempts_allowed")
  
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("quiz_contents")
}

// 5. КОММЕНТАРИИ
model Comment {
  id               String           @id @default(uuid()) @map("comment_id") @db.Char(36)
  
  commentableType  CommentableType  @map("commentable_type")
  commentableId    String           @map("commentable_id") @db.Char(36)
  
  authorProfileId  String           @map("author_profile_id") @db.Char(36)
  author           Profile          @relation(fields: [authorProfileId], references: [id])
  
  text             String           @db.Text
  
  status           ModerationStatus @default(PENDING)
  moderatedBy      String?          @map("moderated_by") @db.Char(36)
  moderator        Profile?         @relation("ModeratedBy", fields: [moderatedBy], references: [id])
  moderatedAt      DateTime?        @map("moderated_at") @db.DateTime(3)
  
  likesCount       Int              @default(0) @map("likes_count")  // Кешированное количество
  
  createdAt        DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt        DateTime?        @map("deleted_at") @db.DateTime(3)

  @@map("comments")
  @@index([commentableType, commentableId])
  @@index([authorProfileId])
  @@index([status])
  @@index([createdAt])
}

// 6. РЕАКЦИИ
model Reaction {
  id               String        @id @default(uuid()) @map("reaction_id") @db.Char(36)
  type             ReactionType
  
  profileId        String        @map("profile_id") @db.Char(36)
  profile          Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  reactionableType ReactionableType @map("reactionable_type")
  reactionableId   String           @map("reactionable_id") @db.Char(36)
  
  createdAt        DateTime      @default(now()) @map("created_at") @db.DateTime(3)

  @@unique([profileId, reactionableType, reactionableId])
  @@map("reactions")
  @@index([reactionableType, reactionableId])
  @@index([profileId])
}

// 7. ИЗБРАННОЕ
model Favorite {
  id             String   @id @default(uuid()) @map("favorite_id") @db.Char(36)
  profileId      String   @map("profile_id") @db.Char(36)
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  lessonId       String   @map("lesson_id") @db.Char(36)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  note           String?  @db.Text
  collection     String?  @db.VarChar(100)
  
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@unique([profileId, lessonId])
  @@map("favorites")
  @@index([profileId])
  @@index([lessonId])
  @@index([collection])
}

// 8. ИСТОРИЯ
model History {
  id             String   @id @default(uuid()) @map("history_id") @db.Char(36)
  profileId      String   @map("profile_id") @db.Char(36)
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  historableType HistorableType @map("historable_type")
  historableId   String         @map("historable_id") @db.Char(36)
  
  watchedSeconds Int?     @map("watched_seconds")
  completed      Boolean  @default(false)
  
  viewedAt       DateTime @default(now()) @map("viewed_at") @db.DateTime(3)

  @@unique([profileId, historableType, historableId])
  @@map("history")
  @@index([profileId])
  @@index([viewedAt])
}

// 9. ПРОГРЕСС
model CourseProgress {
  id             String   @id @default(uuid()) @map("course_progress_id") @db.Char(36)
  profileId      String   @map("profile_id") @db.Char(36)
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  courseId       String   @map("course_id") @db.Char(36)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  status         String   @default("not_started")
  progressPercent Int     @default(0) @map("progress_percent")
  completedLessons Int    @default(0) @map("completed_lessons")
  totalLessons   Int      @default(0) @map("total_lessons")
  
  startedAt      DateTime? @map("started_at") @db.DateTime(3)
  completedAt    DateTime? @map("completed_at") @db.DateTime(3)
  lastViewedAt   DateTime  @default(now()) @map("last_viewed_at") @db.DateTime(3)
  
  @@unique([profileId, courseId])
  @@map("course_progress")
}

model LessonProgress {
  id             String   @id @default(uuid()) @map("lesson_progress_id") @db.Char(36)
  profileId      String   @map("profile_id") @db.Char(36)
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lessonId       String   @map("lesson_id") @db.Char(36)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  status         String   @default("not_started")
  progressPercent Int     @default(0) @map("progress_percent")
  lastPosition   Int?     @map("last_position")
  
  quizScore      Int?     @map("quiz_score")
  quizCompleted  Boolean  @default(false) @map("quiz_completed")
  
  startedAt      DateTime? @map("started_at") @db.DateTime(3)
  completedAt    DateTime? @map("completed_at") @db.DateTime(3)
  lastViewedAt   DateTime  @default(now()) @map("last_viewed_at") @db.DateTime(3)
  
  @@unique([profileId, lessonId])
  @@map("lesson_progress")
}

// 10. ТЕГИ
model Tag {
  id             String   @id @default(uuid()) @map("tag_id") @db.Char(36)
  name           String   @unique @db.VarChar(50)
  slug           String   @unique @db.VarChar(50)
  color          String?  @db.VarChar(7)
  
  courses        CourseTag[]
  lessons        LessonTag[]
  
  @@map("tags")
}

model CourseTag {
  id             String   @id @default(uuid()) @map("course_tag_id") @db.Char(36)
  courseId       String   @map("course_id") @db.Char(36)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tagId          String   @map("tag_id") @db.Char(36)
  tag            Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([courseId, tagId])
  @@map("course_tags")
}

model LessonTag {
  id             String   @id @default(uuid()) @map("lesson_tag_id") @db.Char(36)
  lessonId       String   @map("lesson_id") @db.Char(36)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tagId          String   @map("tag_id") @db.Char(36)
  tag            Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([lessonId, tagId])
  @@map("lesson_tags")
}

// 11. СЕРТИФИКАТЫ
model Certificate {
  id               String   @id @default(uuid()) @map("certificate_id") @db.Char(36)
  profileId        String   @map("profile_id") @db.Char(36)
  profile          Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  courseId         String   @map("course_id") @db.Char(36)
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  issuedAt         DateTime @default(now()) @map("issued_at") @db.DateTime(3)
  completedAt      DateTime @map("completed_at") @db.DateTime(3)
  
  imageUrl         String?  @map("image_url") @db.Text
  pdfUrl           String?  @map("pdf_url") @db.Text
  
  certificateNumber String  @unique @map("certificate_number") @db.VarChar(50)
  metadata         Json?    @map("metadata") @db.Json
  
  @@unique([profileId, courseId])
  @@map("certificates")
}

// ============================================================================
// ОСТАЛЬНЫЕ МОДЕЛИ (Auth, Profile, Payments etc.)
// ============================================================================

model User {
  id             String    @id @default(uuid()) @map("user_id") @db.Char(36)
  email          String    @unique @db.VarChar(255)
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  passwordHash   String?   @map("password_hash") @db.VarChar(255)
  role           Role      @default(USER)
  emailVerified  DateTime? @map("email_verified") @db.DateTime(3)
  isBlocked      Boolean   @default(false) @map("is_blocked")
  blockedReason  String?   @map("blocked_reason") @db.Text
  lastLoginAt    DateTime? @map("last_login_at") @db.DateTime(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt      DateTime? @map("deleted_at") @db.DateTime(3)

  profile        Profile?
  sessions       Session[]
  accounts       Account[]
  Authenticator  Authenticator[]

  @@map("users")
  @@index([email])
  @@index([role])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(uuid()) @map("account_id") @db.Char(36)
  userId            String  @map("user_id") @db.Char(36)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @map("provider_account_id") @db.VarChar(255)
  
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.VarChar(255)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(255)

  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.DateTime(3)
 
  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique @map("credentialID")
  userId               String  @map("user_id") @db.Char(36)
  providerAccountId    String  @map("provider_account_id") @db.VarChar(255)
  credentialPublicKey  String  @map("credentialPublicKey")
  counter              Int
  credentialDeviceType String @map("credentialDeviceType")
  credentialBackedUp   Boolean @map("credentialBackedUp")
  transports           String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([userId, credentialID])
}

model Profile {
  id             String    @id @default(uuid()) @map("profile_id") @db.Char(36)
  userId         String    @unique @map("user_id") @db.Char(36)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  nickname       String    @unique @map("nickname") @db.VarChar(50)
  displayName    String    @map("display_name") @db.VarChar(255)
  avatarUrl      String?   @map("avatar_url") @db.Text
  coverImage     String?   @map("cover_image") @db.Text
  bio            String?   @db.Text
  
  website        String?   @db.VarChar(255)
  telegram       String?   @db.VarChar(100)
  youtube        String?   @db.VarChar(100)
  
  totalViews     Int       @default(0) @map("total_views")
  subscribers    Int       @default(0)
  
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  courses        Course[]
  lessons        Lesson[]
  comments       Comment[]
  reactions      Reaction[]
  favorites      Favorite[]
  history        History[]
  progress       CourseProgress[]
  lessonProgress LessonProgress[]
  certificates   Certificate[]
  subscriptions  Subscription[]
  paymentMethods PaymentMethod[]
  notifications  Notification[]
  transactions   Transaction[]
  businessEvents BusinessEvent[]
  moderatedComments Comment[] @relation("ModeratedBy")

  @@map("profiles")
  @@index([userId])
  @@index([nickname])
}

model Session {
  id           String   @id @default(uuid()) @map("session_id") @db.Char(36)
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       String   @map("user_id") @db.Char(36)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime @db.DateTime(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("sessions")
  @@index([sessionToken])
  @@index([userId])
}

model Subscription {
  id               String             @id @default(uuid()) @map("subscription_id") @db.Char(36)
  profileId        String             @map("profile_id") @db.Char(36)
  profile          Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  planType         String             @map("plan_type") @db.VarChar(50)
  status           SubscriptionStatus @default(ACTIVE) @map("status")
  
  startDate        DateTime           @default(now()) @map("start_date") @db.DateTime(3)
  endDate          DateTime?          @map("end_date") @db.DateTime(3)
  trialEndsAt      DateTime?          @map("trial_ends_at") @db.DateTime(3)
  
  autoRenew        Boolean            @default(true) @map("auto_renew")
  cancelAtPeriodEnd Boolean           @default(false) @map("cancel_at_period_end")
  
  price            Float              @map("price")
  currency         String             @default("RUB") @db.VarChar(3)
  
  paymentMethodId  String?            @map("payment_method_id") @db.Char(36)
  paymentMethod    PaymentMethod?     @relation(fields: [paymentMethodId], references: [id])
  
  providerSubscriptionId String?       @map("provider_subscription_id") @db.VarChar(255)
  provider          String?            @db.VarChar(50)
  
  createdAt        DateTime           @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.DateTime(3)
  canceledAt       DateTime?          @map("canceled_at") @db.DateTime(3)
  deletedAt        DateTime?          @map("deleted_at") @db.DateTime(3)

  transactions     Transaction[]

  @@map("subscriptions")
  @@index([profileId])
  @@index([status])
}

model Transaction {
  id               String             @id @default(uuid()) @map("transaction_id") @db.Char(36)
  profileId        String             @map("profile_id") @db.Char(36)
  profile          Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  subscriptionId   String?            @map("subscription_id") @db.Char(36)
  subscription     Subscription?      @relation(fields: [subscriptionId], references: [id])
  
  type             String             @map("type") @db.VarChar(50)
  amount           Float              @map("amount")
  currency         String             @default("RUB") @db.VarChar(3)
  status           TransactionStatus  @default(PENDING) @map("status")
  
  courseId         String?            @map("course_id") @db.Char(36)
  
  paymentMethodId  String?            @map("payment_method_id") @db.Char(36)
  paymentMethod    PaymentMethod?     @relation(fields: [paymentMethodId], references: [id])
  
  provider         String             @db.VarChar(50)
  providerPaymentId String?           @map("provider_payment_id") @db.VarChar(255)
  providerResponse Json?              @map("provider_response") @db.Json
  
  refundedAt       DateTime?          @map("refunded_at") @db.DateTime(3)
  refundAmount     Float?             @map("refund_amount")
  refundReason     String?            @map("refund_reason") @db.Text
  
  createdAt        DateTime           @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.DateTime(3)
  completedAt      DateTime?          @map("completed_at") @db.DateTime(3)
  failedAt         DateTime?          @map("failed_at") @db.DateTime(3)

  @@map("transactions")
  @@index([profileId])
  @@index([subscriptionId])
  @@index([status])
  @@index([courseId])
}

model PaymentMethod {
  id               String   @id @default(uuid()) @map("payment_method_id") @db.Char(36)
  profileId        String   @map("profile_id") @db.Char(36)
  profile          Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  type             String   @map("type") @db.VarChar(50)
  provider         String   @db.VarChar(50)
  providerToken    String   @map("provider_token") @db.Text
  
  last4            String?  @db.VarChar(4)
  cardType         String?  @map("card_type") @db.VarChar(50)
  expiryMonth      Int?     @map("expiry_month")
  expiryYear       Int?     @map("expiry_year")
  
  phoneNumber      String?  @map("phone_number") @db.VarChar(20)
  
  isDefault        Boolean  @default(false) @map("is_default")
  isVerified       Boolean  @default(false) @map("is_verified")
  isExpired        Boolean  @default(false) @map("is_expired")
  
  metadata         Json?    @map("metadata") @db.Json
  
  createdAt        DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt        DateTime? @map("deleted_at") @db.DateTime(3)

  subscriptions    Subscription[]
  transactions     Transaction[]

  @@map("payment_methods")
  @@index([profileId])
}

model BusinessEvent {
  id               String   @id @default(uuid()) @map("event_id") @db.Char(36)
  profileId        String?  @map("profile_id") @db.Char(36)
  profile          Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  
  eventType        String   @map("event_type") @db.VarChar(100)
  eventCategory    String   @map("event_category") @db.VarChar(50)
  
  objectType       BusinessObjectType?  @map("object_type")
  objectId         String?  @map("object_id") @db.Char(36)
  
  metadata         Json?    @map("metadata") @db.Json
  
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  userAgent        String?  @map("user_agent") @db.Text
  sessionId        String?  @map("session_id") @db.VarChar(255)
  
  createdAt        DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@map("business_events")
  @@index([profileId])
  @@index([eventType])
  @@index([createdAt])
}

model Notification {
  id               String           @id @default(uuid()) @map("notification_id") @db.Char(36)
  profileId        String           @map("profile_id") @db.Char(36)
  profile          Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  type             NotificationType @map("type")
  channel          String           @map("channel") @db.VarChar(50)
  
  title            String           @db.VarChar(255)
  body             String           @db.Text
  data             Json?            @map("data") @db.Json
  
  linkUrl          String?          @map("link_url") @db.Text
  
  isRead           Boolean          @default(false) @map("is_read")
  isSent           Boolean          @default(false) @map("is_sent")
  
  externalId       String?          @map("external_id") @db.VarChar(255)
  
  errorMessage     String?          @map("error_message") @db.Text
  
  scheduledFor     DateTime?        @map("scheduled_for") @db.DateTime(3)
  sentAt           DateTime?        @map("sent_at") @db.DateTime(3)
  readAt           DateTime?        @map("read_at") @db.DateTime(3)
  createdAt        DateTime         @default(now()) @map("created_at") @db.DateTime(3)

  @@map("notifications")
  @@index([profileId])
  @@index([isRead])
  @@index([createdAt])
}
